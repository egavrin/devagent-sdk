{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@devagent-sdk/types": [
        "packages/types/src/index.ts"
      ],
      "@devagent-sdk/schema": [
        "packages/schema/src/index.ts"
      ],
      "@devagent-sdk/validation": [
        "packages/validation/src/index.ts"
      ],
      "@devagent-sdk/changelog": [
        "packages/changelog/src/index.ts"
      ]
    }
  }
}
